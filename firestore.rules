rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Matches + props are written ONLY by Cloud Functions; everyone can read.
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /props/{propId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // A user can read/write only their own profile; points are server-set.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == uid;
      // block client tampering with points/streak — only functions touch those.
      allow update: if request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['points', 'streak']);
    }

    // A slip belongs to its owner. Only the owner can read it (so nobody can
    // copy a rival's picks). `locked` is a one-way latch: once true, no edits.
    match /slips/{slipId} {
      // resource is null when the doc doesn't exist yet — allow that read so a
      // new user's "no slip" subscription resolves to empty instead of erroring.
      allow read: if request.auth != null
                  && (resource == null || request.auth.uid == resource.data.uid);
      // Create your own slip (locked or unlocked — picking then immediately
      // locking is a single create). The latch below governs later edits.
      allow create: if request.auth.uid == request.resource.data.uid;
      // Edit only while still unlocked; you may flip locked false->true, but a
      // locked slip can never be written again, and the owner can't change.
      allow update: if request.auth.uid == resource.data.uid
                    && resource.data.locked == false
                    && request.resource.data.uid == resource.data.uid;
    }

    // Leaderboards: read-only to clients.
    match /leaderboards/{id} { allow read: if request.auth != null; allow write: if false; }

    // Groups: members can read; anyone signed in can create. Joining goes
    // through the joinGroup callable (which validates the code).
    match /groups/{gid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
