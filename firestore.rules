rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A match day's slips can't be created or edited once it has locked
    // (lockAt = the first game's kickoff). Enforced with request.time — the
    // trusted server clock — so it can't be bypassed by changing the device
    // clock or writing straight to the database. Fail-open: with no lock doc
    // for that day, picks are allowed, so a missing doc never blocks real picks.
    function mdUnlocked(day) {
      return !exists(/databases/$(database)/documents/matchdays/$(day))
          || get(/databases/$(database)/documents/matchdays/$(day)).data.get('lockAt', null) == null
          || request.time < get(/databases/$(database)/documents/matchdays/$(day)).data.lockAt;
    }

    // Match-day lock metadata (server/owner-written; rules read it via get()).
    match /matchdays/{day} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Matches + props are written ONLY by Cloud Functions; everyone can read.
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /props/{propId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // A user can read/write only their own profile; points are server-set.
    match /users/{uid} {
      allow read: if request.auth != null;
      // On create, points MUST start at 0 — stops a new account from
      // self-assigning a score (which would game the all-time board).
      allow create: if request.auth.uid == uid
                    && request.resource.data.points == 0;
      // block client tampering with points — only functions touch that.
      allow update: if request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['points']);
    }

    // A slip belongs to its owner. Only the owner can read it (so nobody can
    // copy a rival's picks). `locked` is a one-way latch: once true, no edits.
    match /slips/{slipId} {
      // resource is null when the doc doesn't exist yet — allow that read so a
      // new user's "no slip" subscription resolves to empty instead of erroring.
      allow read: if request.auth != null
                  && (resource == null || request.auth.uid == resource.data.uid);
      // Create your own slip (locked or unlocked — picking then immediately
      // locking is a single create). The latch below governs later edits.
      // settled/scored/streakApplied are server-only — blocking them here stops a
      // client from writing a fake `scored` to game the weekly board.
      allow create: if request.auth.uid == request.resource.data.uid
                    && !request.resource.data.keys().hasAny(['settled', 'scored', 'streakApplied'])
                    && mdUnlocked(request.resource.data.day);
      // Edit only while still unlocked AND before the match day's first kickoff;
      // you may flip locked false->true, but a locked slip can never be written
      // again, and the owner can't change.
      allow update: if request.auth.uid == resource.data.uid
                    && resource.data.locked == false
                    && request.resource.data.uid == resource.data.uid
                    && !request.resource.data.keys().hasAny(['settled', 'scored', 'streakApplied'])
                    && mdUnlocked(resource.data.day);
    }

    // Leaderboards: read-only to clients.
    match /leaderboards/{id} { allow read: if request.auth != null; allow write: if false; }

    // Groups: only members can read (keeps join codes private — no enumerating
    // every group). You create your own group with yourself as the sole member.
    // Joining is server-only: the joinGroup callable validates the code and adds
    // you via the Admin SDK, so direct client updates are blocked.
    match /groups/{gid} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.members.hasOnly([request.auth.uid])
                    && request.resource.data.members.size() == 1;
      allow update, delete: if false;
    }
  }
}
