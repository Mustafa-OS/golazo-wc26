# Copy to ".env" and fill from your Firebase project settings.
# Leaving these blank keeps the app in MOCK_MODE (runs on sample data).
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_APP_ID=

# Local-only: set to 1 (or use `npm run dev:emulator`) to point the real Firebase
# SDK at the local Emulator Suite instead of a live project. Ignored in builds.
# VITE_FB_EMULATOR=1
